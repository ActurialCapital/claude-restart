# Claude Restart - Environment Configuration
# Installed to: ~/.config/claude-restart/<instance>/env
# Permissions: 600 (contains API key)

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=

# Connection mode: remote-control or telegram
CLAUDE_CONNECT=remote-control

# Instance name (used by wrapper for --name flag)
CLAUDE_INSTANCE_NAME=INSTANCE_PLACEHOLDER

# Working directory for this instrument
WORKING_DIRECTORY=WORKING_DIR_PLACEHOLDER

# Per-instance restart file path
CLAUDE_RESTART_FILE=HOME_PLACEHOLDER/.config/claude-restart/INSTANCE_PLACEHOLDER/restart

# Memory limit for this instance (systemd MemoryMax)
CLAUDE_MEMORY_MAX=1G

# Watchdog: forced restart interval in hours (0 to disable)
CLAUDE_WATCHDOG_HOURS=8

# PATH must include claude CLI and wrapper location
PATH=/usr/local/bin:/usr/bin:/bin:HOME_PLACEHOLDER/.local/bin:HOME_PLACEHOLDER/.npm-global/bin:HOME_PLACEHOLDER/.nvm/versions/node/NODEVERSION_PLACEHOLDER/bin:HOME_PLACEHOLDER/.bun/bin

# Channel flag for claude-peers inter-session messaging (leave empty to disable)
CLAUDE_CHANNELS=
