# Claude Restart - Environment Configuration
# Installed to: ~/.config/claude-restart/env
# Permissions: 600 (contains API key)

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=

# Connection mode: remote-control or telegram
CLAUDE_CONNECT=remote-control

# PATH must include claude CLI and wrapper location
PATH=/usr/local/bin:/usr/bin:/bin:HOME_PLACEHOLDER/.local/bin:HOME_PLACEHOLDER/.npm-global/bin:HOME_PLACEHOLDER/.nvm/versions/node/NODEVERSION_PLACEHOLDER/bin
