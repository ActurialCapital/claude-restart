#!/bin/bash
# claude-service: manage the claude systemd user service
set -euo pipefail

# Instance-aware service name (per D-14)
# Usage: claude-service <command> [instance-name]
# Defaults to "default" when instance name omitted (per D-07)
INSTANCE="${2:-default}"
SERVICE="claude@${INSTANCE}.service"
WATCHDOG_TIMER="claude-watchdog.timer"

usage() {
    echo "Usage: claude-service {start|stop|restart|status|logs|watchdog|heartbeat} [instance]"
    echo ""
    echo "Commands:"
    echo "  start      Start the claude service"
    echo "  stop       Stop the claude service"
    echo "  restart    Restart the claude service"
    echo "  status     Show service status"
    echo "  logs       Follow service logs (journalctl)"
    echo "  watchdog   Show watchdog timer status"
    echo "  heartbeat  Show recent heartbeat log entries"
    echo ""
    echo "Instance defaults to 'default' if not specified."
    echo "Examples:"
    echo "  claude-service status              # status of default instance"
    echo "  claude-service status myproject    # status of myproject instance"
}

case "${1:-}" in
    start)
        systemctl --user start "$SERVICE"
        echo "Claude service started (${INSTANCE})"
        ;;
    stop)
        systemctl --user stop "$SERVICE"
        echo "Claude service stopped (${INSTANCE})"
        ;;
    restart)
        systemctl --user restart "$SERVICE"
        echo "Claude service restarted (${INSTANCE})"
        ;;
    status)
        systemctl --user status "$SERVICE"
        ;;
    logs)
        journalctl --user -u "claude@${INSTANCE}" -f
        ;;
    watchdog)
        systemctl --user status "$WATCHDOG_TIMER"
        ;;
    heartbeat)
        journalctl --user -u "claude@${INSTANCE}" --grep="heartbeat sent" --no-pager -n 20
        ;;
    --help|-h|"")
        usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage >&2
        exit 1
        ;;
esac
