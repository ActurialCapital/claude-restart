#!/bin/bash
# claude-service: manage the claude systemd user service
set -euo pipefail

CONFIG_DIR="$HOME/.config/claude-restart"

# Portable sed in-place (macOS needs '' argument, Linux does not)
sed_inplace() {
    if [[ "$(uname -s)" == "Darwin" ]]; then
        sed -i '' "$@"
    else
        sed -i "$@"
    fi
}

deploy_skills() {
    # Deploy GSD skills via official npm installer (requires npx)
    if command -v npx &>/dev/null; then
        echo "Installing GSD skills via npx..."
        if ! npx get-shit-done-cc@latest --global --claude 2>&1; then
            echo "Warning: GSD install failed (skipping)"
        else
            echo "Deployed GSD skills via get-shit-done-cc"
        fi
    else
        echo "Warning: npx not found, skipping GSD skills install"
    fi

    # Deploy superpowers commands via claude plugins (requires claude CLI)
    if command -v claude &>/dev/null; then
        echo "Installing superpowers via claude plugins..."
        if ! claude plugins install superpowers@superpowers-marketplace 2>&1; then
            echo "Warning: superpowers install failed (skipping)"
        else
            echo "Deployed superpowers via claude plugins"
        fi
    else
        echo "Warning: claude CLI not found, skipping superpowers install"
    fi
}

usage() {
    echo "Usage: claude-service <command> [args]"
    echo ""
    echo "Lifecycle commands:"
    echo "  add <name> <git-url>   Add a new instrument"
    echo "  add-orchestra          Register the orchestra instrument (no git clone)"
    echo "  remove [--force] <name> Remove an instrument (prompts for confirmation)"
    echo "  update <name>|--all    Update deployed CLAUDE.md and skills from source repo"
    echo "  list                   List all instruments and status"
    echo ""
    echo "Instance commands:"
    echo "  start [instance]       Start the claude service"
    echo "  stop [instance]        Stop the claude service"
    echo "  restart [instance]     Restart the claude service"
    echo "  status [instance]      Show service status"
    echo "  logs [instance]        Follow service logs (journalctl)"
    echo "  watchdog [instance]    Show watchdog timer status"
    echo "  heartbeat [instance]   Show recent heartbeat log entries"
    echo ""
    echo "Instance defaults to 'default' if not specified."
    echo "Examples:"
    echo "  claude-service add myproject https://github.com/user/repo.git"
    echo "  claude-service remove myproject"
    echo "  claude-service remove --force myproject  # skip confirmation"
    echo "  claude-service list"
    echo "  claude-service add-orchestra"
    echo "  claude-service update --all           # update all instruments"
    echo "  claude-service status              # status of default instance"
    echo "  claude-service status myproject    # status of myproject instance"
}

do_add() {
    local name="$1"
    local git_url="$2"
    local env_dir="$CONFIG_DIR/$name"
    local work_dir="$HOME/instruments/$name"
    local template="$CONFIG_DIR/env.template"
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    # Validate name (alphanumeric + hyphens only, must start with alphanumeric)
    if [[ ! "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9-]*$ ]]; then
        echo "Error: instrument name must match ^[a-zA-Z0-9][a-zA-Z0-9-]*$" >&2
        exit 1
    fi

    # Check for duplicate
    if [[ -d "$env_dir" ]]; then
        echo "Error: instrument '$name' already exists at $env_dir" >&2
        exit 1
    fi

    # Check template exists
    if [[ ! -f "$template" ]]; then
        echo "Error: env.template not found at $template" >&2
        echo "Run install.sh first to deploy the template." >&2
        exit 1
    fi

    # Check default instance exists (for API key copy)
    local default_env="$CONFIG_DIR/default/env"
    if [[ ! -f "$default_env" ]]; then
        echo "Error: default instance env not found at $default_env" >&2
        echo "A default instance must exist to copy the API key from." >&2
        exit 1
    fi

    # Clone repo
    echo "Cloning $git_url to $work_dir..."
    git clone "$git_url" "$work_dir"

    # Deploy instrument identity CLAUDE.md (Phase 14, per D-03)
    local claude_md_template
    claude_md_template="$script_dir/../INSTRUMENT.md.template"
    if [[ -f "$claude_md_template" ]]; then
        mkdir -p "$work_dir/.claude"
        cp "$claude_md_template" "$work_dir/.claude/CLAUDE.md"
        sed_inplace "s|INSTANCE_PLACEHOLDER|$name|g" "$work_dir/.claude/CLAUDE.md"
        echo "Deployed instrument identity to $work_dir/.claude/CLAUDE.md"
    fi

    # Create env from template
    mkdir -p "$env_dir"
    cp "$template" "$env_dir/env"

    # Replace placeholders (same pattern as install.sh)
    sed_inplace "s|INSTANCE_PLACEHOLDER|$name|g" "$env_dir/env"
    sed_inplace "s|WORKING_DIR_PLACEHOLDER|$work_dir|g" "$env_dir/env"
    sed_inplace "s|HOME_PLACEHOLDER|$HOME|g" "$env_dir/env"

    # Copy API key from default instance
    local api_key
    api_key=$(grep '^ANTHROPIC_API_KEY=' "$default_env" | cut -d= -f2)
    sed_inplace "s|^ANTHROPIC_API_KEY=.*|ANTHROPIC_API_KEY=$api_key|" "$env_dir/env"

    # Copy PATH line from default instance (avoids node version detection issues)
    local default_path
    default_path=$(grep '^PATH=' "$default_env")
    if [[ -n "$default_path" ]]; then
        sed_inplace "s|^PATH=.*|$default_path|" "$env_dir/env"
    fi

    chmod 600 "$env_dir/env"

    # Enable systemd units (service + watchdog)
    systemctl --user daemon-reload
    systemctl --user enable --now "claude@${name}.service"
    systemctl --user enable --now "claude-watchdog@${name}.timer"

    echo "Instrument '$name' added and started"
    echo "  Service: claude@${name}.service"
    echo "  Watchdog: claude-watchdog@${name}.timer"
    echo "  Config: $env_dir/env"
    echo "  Working dir: $work_dir"
}

do_add_orchestra() {
    local name="orchestra"
    local env_dir="$CONFIG_DIR/$name"
    local work_dir="$HOME/instruments/$name"
    local template="$CONFIG_DIR/env.template"
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local claude_config="$HOME/.claude.json"

    # Check for duplicate
    if [[ -d "$env_dir" ]]; then
        echo "Error: orchestra already exists at $env_dir" >&2
        exit 1
    fi

    # Check template exists
    if [[ ! -f "$template" ]]; then
        echo "Error: env.template not found at $template" >&2
        echo "Run install.sh first to deploy the template." >&2
        exit 1
    fi

    # Check default instance exists (for API key copy)
    local default_env="$CONFIG_DIR/default/env"
    if [[ ! -f "$default_env" ]]; then
        echo "Error: default instance env not found at $default_env" >&2
        echo "A default instance must exist to copy the API key from." >&2
        exit 1
    fi

    # Check orchestra CLAUDE.md source exists
    local claude_md_src="$script_dir/../orchestra/CLAUDE.md"
    if [[ ! -f "$claude_md_src" ]]; then
        echo "Error: orchestra/CLAUDE.md not found at $claude_md_src" >&2
        echo "The orchestra behavioral spec is required for add-orchestra." >&2
        exit 1
    fi

    # Create working directory (no git clone)
    mkdir -p "$work_dir"

    # Deploy orchestra CLAUDE.md behavioral spec
    cp "$claude_md_src" "$work_dir/CLAUDE.md"
    echo "Deployed orchestra CLAUDE.md to $work_dir/CLAUDE.md"

    # Deploy orchestra identity hint (supplements the behavioral spec above)
    mkdir -p "$work_dir/.claude"
    cat > "$work_dir/.claude/CLAUDE.md" << IDENTITY
# Instrument: orchestra

You are the **orchestra** supervisor instance. Your behavioral spec is in CLAUDE.md at the repo root.

## Context Reset

\`\`\`
claude-restart --instance orchestra
\`\`\`
IDENTITY
    echo "Deployed orchestra identity to $work_dir/.claude/CLAUDE.md"

    # Create env from template
    mkdir -p "$env_dir"
    cp "$template" "$env_dir/env"

    # Replace placeholders
    sed_inplace "s|INSTANCE_PLACEHOLDER|$name|g" "$env_dir/env"
    sed_inplace "s|WORKING_DIR_PLACEHOLDER|$work_dir|g" "$env_dir/env"
    sed_inplace "s|HOME_PLACEHOLDER|$HOME|g" "$env_dir/env"

    # Copy API key from default instance
    local api_key
    api_key=$(grep '^ANTHROPIC_API_KEY=' "$default_env" | cut -d= -f2)
    sed_inplace "s|^ANTHROPIC_API_KEY=.*|ANTHROPIC_API_KEY=$api_key|" "$env_dir/env"

    # Copy PATH line from default instance
    local default_path
    default_path=$(grep '^PATH=' "$default_env")
    if [[ -n "$default_path" ]]; then
        sed_inplace "s|^PATH=.*|$default_path|" "$env_dir/env"
    fi

    chmod 600 "$env_dir/env"

    # Pre-set remoteDialogSeen for non-interactive remote-control startup
    if [[ -f "$claude_config" ]] && command -v jq &>/dev/null; then
        local tmp
        tmp=$(jq '.remoteDialogSeen = true' "$claude_config") && echo "$tmp" > "$claude_config"
        echo "Set remoteDialogSeen=true in $claude_config"
    elif [[ ! -f "$claude_config" ]]; then
        echo '{"remoteDialogSeen": true}' > "$claude_config"
        echo "Created $claude_config with remoteDialogSeen=true"
    fi

    # Enable systemd units
    systemctl --user daemon-reload
    systemctl --user enable --now "claude@${name}.service"
    systemctl --user enable --now "claude-watchdog@${name}.timer"

    echo "Orchestra instrument registered and started"
    echo "  Service: claude@${name}.service"
    echo "  Watchdog: claude-watchdog@${name}.timer"
    echo "  Config: $env_dir/env"
    echo "  Working dir: $work_dir"
}

do_remove() {
    local name="$1"
    local force="${2:-false}"
    local env_dir="$CONFIG_DIR/$name"
    local work_dir="$HOME/instruments/$name"

    # Prevent removing default instance
    if [[ "$name" == "default" ]]; then
        echo "Error: cannot remove the default instance" >&2
        exit 1
    fi

    # Check instrument exists
    if [[ ! -d "$env_dir" ]]; then
        echo "Error: instrument '$name' not found" >&2
        exit 1
    fi

    # Confirm removal (skip with --force)
    if [[ "$force" != "true" ]]; then
        echo "Will permanently delete instrument '$name':"
        echo "  Config:  $env_dir"
        echo "  Working: $work_dir"
        if [[ -d "$work_dir" ]]; then
            local uncommitted
            uncommitted=$(git -C "$work_dir" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
            if [[ "$uncommitted" -gt 0 ]]; then
                echo "  WARNING: $work_dir contains $uncommitted uncommitted change(s)"
            fi
        fi
        echo ""
        printf "Type 'yes' to confirm: "
        read -r answer
        if [[ "$answer" != "yes" ]]; then
            echo "Aborted."
            exit 1
        fi
    fi

    # Stop and disable systemd units
    systemctl --user stop "claude@${name}.service" 2>/dev/null || true
    systemctl --user disable "claude@${name}.service" 2>/dev/null || true
    systemctl --user stop "claude-watchdog@${name}.timer" 2>/dev/null || true
    systemctl --user disable "claude-watchdog@${name}.timer" 2>/dev/null || true

    # Delete config directory
    rm -rf "$env_dir"

    # Delete working directory
    rm -rf "$work_dir"

    echo "Instrument '$name' removed"
    echo "  Stopped and disabled: claude@${name}.service, claude-watchdog@${name}.timer"
    echo "  Deleted: $env_dir"
    echo "  Deleted: $work_dir"
}

do_list() {
    printf "%-20s %-10s\n" "INSTRUMENT" "STATUS"
    printf "%-20s %-10s\n" "----------" "------"
    for dir in "$CONFIG_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        local status
        status=$(systemctl --user is-active "claude@${name}.service" 2>/dev/null || echo "unknown")
        printf "%-20s %-10s\n" "$name" "$status"
    done
}

do_update() {
    local name="$1"
    local env_dir="$CONFIG_DIR/$name"
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    # Check instrument exists
    if [[ ! -d "$env_dir" ]]; then
        echo "Error: instrument '$name' not found" >&2
        exit 1
    fi

    # Resolve work_dir from env file
    local work_dir
    work_dir=$(grep '^WORKING_DIRECTORY=' "$env_dir/env" | cut -d= -f2)

    if [[ "$name" == "orchestra" ]]; then
        # Re-deploy orchestra behavioral spec
        cp "$script_dir/../orchestra/CLAUDE.md" "$work_dir/CLAUDE.md"
        echo "Updated orchestra behavioral spec at $work_dir/CLAUDE.md"

        # Re-deploy orchestra identity hint
        mkdir -p "$work_dir/.claude"
        cat > "$work_dir/.claude/CLAUDE.md" << IDENTITY
# Instrument: orchestra

You are the **orchestra** supervisor instance. Your behavioral spec is in CLAUDE.md at the repo root.

## Context Reset

\`\`\`
claude-restart --instance orchestra
\`\`\`
IDENTITY
        echo "Updated orchestra identity at $work_dir/.claude/CLAUDE.md"
    else
        # Re-deploy instrument identity CLAUDE.md
        mkdir -p "$work_dir/.claude"
        cp "$script_dir/../INSTRUMENT.md.template" "$work_dir/.claude/CLAUDE.md"
        sed_inplace "s|INSTANCE_PLACEHOLDER|$name|g" "$work_dir/.claude/CLAUDE.md"
        echo "Updated instrument identity at $work_dir/.claude/CLAUDE.md"
    fi
}

do_update_all() {
    for dir in "$CONFIG_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        do_update "$name"
    done
    deploy_skills
}

case "${1:-}" in
    add)
        if [[ -z "${2:-}" || -z "${3:-}" ]]; then
            echo "Usage: claude-service add <name> <git-url>" >&2
            exit 1
        fi
        do_add "$2" "$3"
        ;;
    add-orchestra)
        do_add_orchestra
        ;;
    remove)
        force=false
        remove_name=""
        shift  # past 'remove'
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --force) force=true ;;
                *) remove_name="$1" ;;
            esac
            shift
        done
        if [[ -z "$remove_name" ]]; then
            echo "Usage: claude-service remove [--force] <name>" >&2
            exit 1
        fi
        do_remove "$remove_name" "$force"
        ;;
    list)
        do_list
        ;;
    update)
        if [[ "${2:-}" == "--all" ]]; then
            do_update_all
        elif [[ -n "${2:-}" ]]; then
            do_update "$2"
            deploy_skills
        else
            echo "Usage: claude-service update <name>|--all" >&2
            exit 1
        fi
        ;;
    start|stop|restart|status|logs|watchdog|heartbeat)
        # Instance-aware commands (existing)
        INSTANCE="${2:-default}"
        SERVICE="claude@${INSTANCE}.service"
        case "$1" in
            start)
                systemctl --user start "$SERVICE"
                echo "Claude service started (${INSTANCE})"
                ;;
            stop)
                systemctl --user stop "$SERVICE"
                echo "Claude service stopped (${INSTANCE})"
                ;;
            restart)
                systemctl --user restart "$SERVICE"
                echo "Claude service restarted (${INSTANCE})"
                ;;
            status)
                systemctl --user status "$SERVICE"
                ;;
            logs)
                journalctl --user -u "claude@${INSTANCE}" -f
                ;;
            watchdog)
                systemctl --user status "claude-watchdog@${INSTANCE}.timer"
                ;;
            heartbeat)
                journalctl --user -u "claude@${INSTANCE}" --grep="heartbeat sent" --no-pager -n 20
                ;;
        esac
        ;;
    --help|-h|"")
        usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage >&2
        exit 1
        ;;
esac
