#!/bin/bash
# claude-wrapper: runs claude in a loop, relaunching on restart signal

RESTART_FILE="${CLAUDE_RESTART_FILE:-$HOME/.claude-restart}"

# Change to working directory if set (systemd can't expand env vars in WorkingDirectory=)
if [[ -n "${WORKING_DIRECTORY:-}" && -d "$WORKING_DIRECTORY" ]]; then
    cd "$WORKING_DIRECTORY"
fi
MAX_RESTARTS="${CLAUDE_WRAPPER_MAX_RESTARTS:-10}"
RESTART_DELAY="${CLAUDE_WRAPPER_DELAY:-2}"
HEARTBEAT_INTERVAL="${CLAUDE_WRAPPER_HEARTBEAT_INTERVAL:-300}"
restart_count=0

# Store original args for "empty file = restart with same options" behavior
original_args=("$@")
current_args=("$@")

# Mode selection (per CLAUDE_CONNECT env var)
mode_args=()
case "${CLAUDE_CONNECT:-}" in
    remote-control)
        mode_args=("remote-control" "--permission-mode" "bypassPermissions")
        if [[ -n "${CLAUDE_INSTANCE_NAME:-}" && "${CLAUDE_INSTANCE_NAME}" != "default" ]]; then
            mode_args+=("--name" "$CLAUDE_INSTANCE_NAME")
        fi
        ;;
    telegram)
        mode_args=("--channels" "plugin:telegram@claude-plugins-official")
        ;;
    "")
        # Interactive mode -- no mode args, use passed args only
        ;;
    *)
        echo "claude-wrapper: unknown CLAUDE_CONNECT mode: $CLAUDE_CONNECT" >&2
        echo "claude-wrapper: valid values: remote-control, telegram, or unset for interactive" >&2
        exit 1
        ;;
esac

# Filter --dangerously-skip-permissions from current_args in remote-control mode
# (remote-control uses --permission-mode bypassPermissions instead)
if [[ "${CLAUDE_CONNECT:-}" == "remote-control" ]]; then
    filtered_args=()
    for arg in "${current_args[@]}"; do
        if [[ "$arg" != "--dangerously-skip-permissions" ]]; then
            filtered_args+=("$arg")
        fi
    done
    current_args=("${filtered_args[@]}")
fi

# Channel support for claude-peers (per D-08, D-11)
channel_args=()
if [[ -n "${CLAUDE_CHANNELS:-}" ]]; then
    channel_args=("--dangerously-load-development-channels" "$CLAUDE_CHANNELS")
fi

# Ensure remoteDialogSeen is set in claude global config (bypasses "Enable Remote Control?" prompt)
ensure_remote_dialog_seen() {
    local config_file="$HOME/.claude.json"
    if [[ -f "$config_file" ]]; then
        # Check if remoteDialogSeen is already true
        if command -v jq &>/dev/null; then
            if [[ "$(jq -r '.remoteDialogSeen // false' "$config_file" 2>/dev/null)" == "true" ]]; then
                return 0
            fi
            # Set it using jq
            local tmp
            tmp=$(jq '.remoteDialogSeen = true' "$config_file") && echo "$tmp" > "$config_file"
        elif command -v python3 &>/dev/null; then
            python3 -c "
import json, sys
with open('$config_file') as f: d = json.load(f)
if d.get('remoteDialogSeen') == True: sys.exit(0)
d['remoteDialogSeen'] = True
with open('$config_file', 'w') as f: json.dump(d, f, indent=2)
"
        else
            echo "claude-wrapper: warning: cannot set remoteDialogSeen (install jq or python3)" >&2
        fi
    else
        # Create minimal config
        echo '{"remoteDialogSeen": true}' > "$config_file"
    fi
}

# Track child process for signal forwarding
child_pid=""
heartbeat_pid=""
HEARTBEAT_FIFO=""

# Heartbeat cleanup helper
stop_heartbeat() {
    if [[ -n "$heartbeat_pid" ]]; then
        kill "$heartbeat_pid" 2>/dev/null; wait "$heartbeat_pid" 2>/dev/null || true
        heartbeat_pid=""
    fi
    rm -f "${HEARTBEAT_FIFO:-}" 2>/dev/null
}

# Signal handlers
trap 'stop_heartbeat; if [[ -n "$child_pid" ]]; then kill -TERM "$child_pid" 2>/dev/null; wait "$child_pid" 2>/dev/null; fi; rm -f "${HEARTBEAT_FIFO:-}" 2>/dev/null; exit 0' TERM
trap '' HUP
trap 'exit 130' INT

while true; do
    # Heartbeat setup (telegram mode only, per D-04, D-11, D-16)
    heartbeat_pid=""
    if [[ "${CLAUDE_CONNECT:-}" == "telegram" ]]; then
        HEARTBEAT_FIFO=$(mktemp -u /tmp/claude-heartbeat.XXXXXX)
        mkfifo "$HEARTBEAT_FIFO"
        # Launch claude reading from FIFO for stdin
        claude "${channel_args[@]}" "${mode_args[@]}" "${current_args[@]}" < "$HEARTBEAT_FIFO" &
        child_pid=$!
        # Start heartbeat writer in background
        (
            _hb_sleep_pid=""
            trap 'kill "$_hb_sleep_pid" 2>/dev/null; exec 3>&- 2>/dev/null; exit 0' TERM
            # Keep FIFO open for writing (open as fd 3)
            exec 3>"$HEARTBEAT_FIFO"
            while kill -0 "$child_pid" 2>/dev/null; do
                sleep "$HEARTBEAT_INTERVAL" &
                _hb_sleep_pid=$!
                wait $_hb_sleep_pid 2>/dev/null || break
                _hb_sleep_pid=""
                echo "" >&3 2>/dev/null || break
                echo "claude-wrapper: heartbeat sent $(date -u +%Y-%m-%dT%H:%M:%SZ)" >&2
            done
            exec 3>&- 2>/dev/null
        ) &
        heartbeat_pid=$!
    elif [[ "${CLAUDE_CONNECT:-}" == "remote-control" ]]; then
        ensure_remote_dialog_seen
        # remote-control inherits stdin to spawned sessions. /dev/null causes
        # immediate EOF; sessions die with "--print mode needs input". Use a
        # FIFO held open (no EOF) but never written to (no stale data).
        HEARTBEAT_FIFO=$(mktemp -u /tmp/claude-heartbeat.XXXXXX)
        mkfifo "$HEARTBEAT_FIFO"
        claude "${channel_args[@]}" "${mode_args[@]}" "${current_args[@]}" < "$HEARTBEAT_FIFO" &
        child_pid=$!
        # Hold FIFO write-end open so read-side never gets EOF
        (
            trap 'exec 3>&- 2>/dev/null; exit 0' TERM
            exec 3>"$HEARTBEAT_FIFO"
            # Block until claude exits — no writes needed
            while kill -0 "$child_pid" 2>/dev/null; do
                sleep 60 &
                wait $! 2>/dev/null || break
            done
            exec 3>&- 2>/dev/null
        ) &
        heartbeat_pid=$!
    else
        claude "${channel_args[@]}" "${mode_args[@]}" "${current_args[@]}" &
        child_pid=$!
    fi
    wait "$child_pid" 2>/dev/null
    exit_code=$?
    child_pid=""
    # Stop heartbeat if running
    stop_heartbeat

    # If wait was interrupted by a signal (exit_code > 128), the trap handler
    # already dealt with it. For TERM the trap exits; for others, continue loop.
    if [[ $exit_code -gt 128 ]]; then
        continue
    fi

    # Mode-aware restart: mode_args (from CLAUDE_CONNECT) are fixed at launch.
    # Restart file content replaces only current_args (extra args).
    # Mode is never lost on restart (per D-09).

    # Check for restart signal
    if [[ -f "$RESTART_FILE" ]]; then
        restart_count=$((restart_count + 1))

        if [[ $restart_count -gt $MAX_RESTARTS ]]; then
            echo "claude-wrapper: Maximum restarts ($MAX_RESTARTS) reached. Exiting." >&2
            rm -f "$RESTART_FILE"
            exit 1
        fi

        # Read new options from file
        new_opts=$(cat "$RESTART_FILE")
        rm -f "$RESTART_FILE"

        if [[ -n "$new_opts" ]]; then
            # File has content: use those as new args
            # Split the string into an array (word splitting is intentional)
            read -ra current_args <<< "$new_opts"
            echo "Restarting claude with: ${mode_args[*]:+${mode_args[*]} }${current_args[*]}"
        else
            # Empty file: restart with original launch options
            current_args=("${original_args[@]}")
            if [[ ${#current_args[@]} -gt 0 || ${#mode_args[@]} -gt 0 ]]; then
                echo "Restarting claude with: ${mode_args[*]:+${mode_args[*]} }${current_args[*]}"
            else
                echo "Restarting claude..."
            fi
        fi

        sleep "$RESTART_DELAY"
    else
        # No restart file: exit the wrapper
        exit $exit_code
    fi
done
